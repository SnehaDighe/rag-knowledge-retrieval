apiVersion: v1
kind: Secret
metadata:
  name: rag-secrets
  namespace: rag-system
type: Opaque
stringData:
  # Update these with your actual API keys
  # For production, use sealed-secrets or external-secrets
  OPENAI_API_KEY: "your-openai-api-key-here"
  PINECONE_API_KEY: "your-pinecone-api-key-here"
